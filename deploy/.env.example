# AI 面试助手环境变量配置
# 复制此文件为 .env 并填写实际值

# OpenAI API 配置（如果使用 AI 功能）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：其他 AI 服务配置
# MOONSHOT_API_KEY=your_moonshot_api_key
# DEEPSEEK_API_KEY=your_deepseek_api_key

# CORS 配置（生产环境需要添加你的域名）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://49.51.141.84

# 应用配置
APP_ENV=production
LOG_LEVEL=info
