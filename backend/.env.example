# AI 面试助手环境变量配置

# ============================================
# 百度搜索 API（必须）
# 获取地址：https://console.bce.baidu.com/qianfan/ais/console/applicationConsole
# ============================================
BAIDU_API_KEY=your_baidu_api_key_here

# ============================================
# LLM API 配置（二选一，推荐 Moonshot/Kimi）
# ============================================

# 选项1：Moonshot (Kimi) - 推荐国内使用
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2-turbo-preview

# 选项2：OpenAI
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ============================================
# CORS 配置
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://49.51.141.84

# ============================================
# 应用配置
# ============================================
APP_ENV=development
LOG_LEVEL=info
